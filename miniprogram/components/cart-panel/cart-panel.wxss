.cart-panel {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background-color: var(--bg-white);
  border-radius: 16px 16px 0 0;
  max-height: 70vh;
  padding: 16px;
}

.panel-title {
  font-size: 16px;
  font-weight: 500;
  text-align: center;
  margin-bottom: 12px;
}

.cart-empty {
  text-align: center;
  color: var(--color-text-muted);
  padding: 20px 0;
}

.cart-item {
  display: flex;
  align-items: center;
  padding: 10px 0;
  border-bottom: 1px solid #f0f0f0;
}

.cart-item-name {
  font-size: 15px;
  font-weight: 500;
  flex: 1;
}

.cart-item-meta {
  font-size: 12px;
  color: var(--color-text-muted);
}

.cart-item-remove {
  font-size: 13px;
  color: var(--color-danger);
  margin-left: 12px;
}

.cart-actions {
  display: flex;
  gap: 12px;
  margin-top: 16px;
}

.cart-actions .btn-primary {
  flex: 2;
}

.cart-actions .btn-secondary {
  flex: 1;
}