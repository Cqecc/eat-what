.order-confirm {
  width: 85%;
}

.confirm-title {
  font-size: 16px;
  font-weight: 500;
  text-align: center;
  margin-bottom: 12px;
}

.confirm-items {
  margin-bottom: 12px;
}

.confirm-item {
  display: flex;
  align-items: center;
  padding: 8px 0;
  border-bottom: 1px solid #f0f0f0;
}

.confirm-item-name {
  font-size: 15px;
  font-weight: 500;
}

.confirm-item-meta {
  font-size: 12px;
  color: var(--color-text-muted);
  margin-left: 8px;
}

.confirm-note {
  margin-bottom: 16px;
}

.confirm-note input {
  width: 100%;
  padding: 8px 10px;
  border: 1px solid #e0e0e0;
  border-radius: 6px;
  font-size: 14px;
}

.confirm-actions {
  display: flex;
  gap: 12px;
}

.confirm-actions .btn-primary { flex: 2; }
.confirm-actions .btn-secondary { flex: 1; }