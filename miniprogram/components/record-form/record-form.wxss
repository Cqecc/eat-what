.record-form {
  padding: 16px;
}

.form-row {
  margin-bottom: 12px;
}

.form-row-group {
  display: flex;
  align-items: center;
}

.form-label {
  font-size: 14px;
  color: var(--color-text-secondary);
  width: 50px;
}

.form-options {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
}

.option-btn {
  padding: 6px 16px;
  border-radius: 20px;
  font-size: 13px;
  background-color: #f0f0f0;
  color: var(--color-text-secondary);
}

.option-btn.active {
  background-color: var(--color-primary);
  color: #fff;
}

.rating-btn.good.active {
  background-color: var(--color-primary);
}

.rating-btn.ok.active {
  background-color: #aaa;
}

.form-input {
  width: 100%;
  padding: 10px 12px;
  border: 1px solid #e0e0e0;
  border-radius: var(--radius-sm);
  font-size: 14px;
  background-color: var(--bg-white);
}

.name-input {
  font-size: 16px;
  font-weight: 500;
}

.photo-section {
  margin-bottom: 16px;
}

.photo-area {
  width: 80px;
  height: 80px;
  border-radius: var(--radius-sm);
  overflow: hidden;
  background-color: #f5f5f5;
  display: flex;
  align-items: center;
  justify-content: center;
}

.photo-thumb {
  width: 100%;
  height: 100%;
}

.photo-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.photo-icon {
  font-size: 24px;
}

.photo-text {
  font-size: 11px;
  color: var(--color-text-muted);
}

.form-actions {
  margin-top: 20px;
}