.toast-container {
  position: fixed;
  top: 60px;
  left: 50%;
  transform: translateX(-50%);
  z-index: 200;
}

.toast-box {
  padding: 10px 20px;
  border-radius: 8px;
  font-size: 14px;
  background-color: rgba(0,0,0,0.7);
  color: #fff;
}

.toast-box.success {
  background-color: var(--color-success);
}

.toast-box.error {
  background-color: var(--color-danger);
}