.home-page {
  padding: 16px;
}

.state-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 100px;
}

.state-text {
  font-size: 16px;
  color: var(--color-text-muted);
}

.retry-btn {
  margin-top: 16px;
  width: 120px;
}

.meal-hint {
  text-align: center;
  font-size: 16px;
  color: var(--color-primary);
  font-weight: 500;
  padding: 12px 0;
}

.home-filter {
  display: flex;
  gap: 8px;
  justify-content: center;
  margin-bottom: 20px;
}

.filter-btn {
  padding: 6px 14px;
  border-radius: 20px;
  font-size: 13px;
  background-color: #f0f0f0;
  color: var(--color-text-secondary);
}

.filter-btn.active {
  background-color: var(--color-primary);
  color: #fff;
}

.home-initial {
  display: flex;
  justify-content: center;
  padding-top: 60px;
}

.spin-btn {
  width: 180px;
  height: 180px;
  border-radius: 50%;
  background-color: var(--color-primary);
  color: #fff;
  font-size: 24px;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8px 24px rgba(255,107,53,0.3);
}

.spin-btn-active {
  transform: scale(0.95);
  opacity: 0.9;
}

.home-spinning {
  display: flex;
  justify-content: center;
  padding-top: 80px;
}

.spin-text {
  font-size: 18px;
  color: var(--color-text-muted);
}

.exhausted-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 80px;
}

.exhausted-text {
  font-size: 14px;
  color: var(--color-text-muted);
  margin-bottom: 16px;
}

.invite-tip {
  width: 80%;
  text-align: center;
}

.invite-title {
  font-size: 16px;
  font-weight: 500;
}

.invite-desc {
  font-size: 13px;
  color: var(--color-text-muted);
  margin-top: 8px;
  margin-bottom: 16px;
}

.invite-share-btn {
  margin-top: 0;
  padding: 12px 0;
  border: none;
  line-height: normal;
}

.invite-share-btn::after { border: none; }

.btn-skip {
  text-align: center;
  color: var(--color-text-muted);
  font-size: 13px;
  margin-top: 10px;
}