<view class="mine-page">
  <!-- 加载态 -->
  <view wx:if="{{loadingState}}" class="state-container">
    <text class="state-text">加载中...</text>
  </view>

  <!-- 错误态 -->
  <view wx:elif="{{loadErrorState}}" class="state-container">
    <text class="state-text">数据加载失败</text>
    <view class="btn-primary retry-btn" bindtap="retryLoad">重试</view>
  </view>

  <!-- 正常态 -->
  <view wx:else>
    <!-- 统计卡片 -->
    <view class="stats-section">
      <view class="stats-card card">
        <view class="stat-item">
          <text class="stat-value">{{totalCount}}</text>
          <text class="stat-label">总记录</text>
        </view>
        <view class="stat-item">
          <text class="stat-value">{{goodCount}}</text>
          <text class="stat-label">好吃</text>
        </view>
        <view class="stat-item">
          <text class="stat-value">{{okCount}}</text>
          <text class="stat-label">还行</text>
        </view>
      </view>
    </view>

    <!-- 分类统计 -->
    <view class="category-section">
      <view class="section-title">分类统计</view>
      <view class="category-list">
        <view wx:for="{{categoryStats}}" wx:key="name" class="category-card card" bindtap="onCategoryTap" data-name="{{item.name}}">
          <text class="category-icon">{{item.icon}}</text>
          <text class="category-name">{{item.name}}</text>
          <text class="category-count">{{item.count}}道</text>
          <text class="category-good">{{item.goodCount}}好吃</text>
        </view>
      </view>
    </view>

    <!-- 最近订单 -->
    <view class="order-section">
      <view class="section-title">最近订单</view>
      <view wx:if="{{orders.length === 0}}" class="empty-text">暂无订单</view>
      <view wx:else>
        <view wx:for="{{orders}}" wx:key="_id" class="order-card card">
          <view class="order-header">
            <text class="order-date">{{item.createdAtStr}}</text>
            <text class="order-status">{{item.status}}</text>
          </view>
          <view class="order-items">
            <text wx:for="{{item.items}}" wx:for-item="dish" wx:key="name">{{dish.name}}</text>
          </view>
          <view wx:if="{{item.note}}" class="order-note">{{item.note}}</view>
        </view>
      </view>
    </view>
  </view>
</view>