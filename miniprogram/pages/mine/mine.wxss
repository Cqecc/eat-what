.mine-page {
  padding: 16px;
}

.state-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 100px;
}

.state-text {
  font-size: 16px;
  color: var(--color-text-muted);
}

.retry-btn {
  margin-top: 16px;
  width: 120px;
}

.stats-card {
  display: flex;
  justify-content: space-around;
}

.stat-item {
  text-align: center;
}

.stat-value {
  font-size: 24px;
  font-weight: 600;
  color: var(--color-primary);
}

.stat-label {
  font-size: 12px;
  color: var(--color-text-muted);
}

.section-title {
  font-size: 15px;
  font-weight: 500;
  margin-bottom: 10px;
}

.category-section {
  margin-top: 20px;
}

.category-list {
  display: flex;
  gap: 10px;
  flex-wrap: wrap;
}

.category-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 12px;
  width: calc(50% - 5px);
}

.category-icon {
  font-size: 20px;
}

.category-name {
  font-size: 14px;
  font-weight: 500;
}

.category-count {
  font-size: 12px;
  color: var(--color-text-secondary);
}

.category-good {
  font-size: 11px;
  color: var(--color-primary);
}

.order-section {
  margin-top: 20px;
}

.empty-text {
  text-align: center;
  color: var(--color-text-muted);
  padding: 16px 0;
}

.order-card {
  margin-bottom: 10px;
}

.order-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.order-date {
  font-size: 13px;
  color: var(--color-text-muted);
}

.order-status {
  font-size: 12px;
  color: var(--color-primary);
}

.order-items {
  margin-top: 6px;
  font-size: 14px;
}

.order-items text {
  margin-right: 8px;
}

.order-note {
  font-size: 13px;
  color: var(--color-text-secondary);
  margin-top: 4px;
}